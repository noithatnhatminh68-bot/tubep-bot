      "parameters": { "handleErrors": false },
      "mapper": {
        "url": "https://api.anthropic.com/v1/messages",
        "method": "post",
        "headers": [
          { "name": "x-api-key", "value": "DIEN_CLAUDE_API_KEY_VAO_DAY" },
          { "name": "anthropic-version", "value": "2023-06-01" }
        ],
        "bodyType": "raw",
        "parseResponse": true,
        "contentType": "application/json",
        "data": "{\"model\":\"claude-opus-4-5\",\"max_tokens\":800,\"messages\":[{\"role\":\"user\",\"content\":\"Viet 1 bai dang Facebook cho Tu Bep Phuong Nam - tu bep canh kinh cao cap (80% nhom 20% inox), showroom TP.HCM. Yeu cau: 150-200 chu, tone than thien chuyen nghiep, co emoji, CTA keu goi nhan tin hoac den showroom, 5-7 hashtag. Chi viet bai, khong giai thich. Viet tieng Viet co dau.\"}]}"
      },
      "metadata": { "designer": { "x": 0, "y": 0 } }
    },
    {
      "id": 2,
